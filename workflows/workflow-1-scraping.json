    {
      "parameters": {
        "jsCode": "const newTweets = $('Filtrar Engajamento Alto').all();\nconst existingPosts = $('Buscar Posts Existentes').all();\n\nconst existingIds = new Set(\n  existingPosts.map(p => p.json.tweet_id)\n);\n\nconst uniqueTweets = newTweets.filter(\n  t => !existingIds.has(t.json.tweet_id)\n);\n\nif (uniqueTweets.length === 0) {\n  return [{ json: { message: 'Nenhum tweet novo', count: 0 } }];\n}\n\nreturn uniqueTweets;"
      },
