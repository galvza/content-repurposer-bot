    {
      "parameters": {
        "jsCode": "const tweets = $input.all();\nconst results = [];\n\nfor (const item of tweets) {\n  const t = item.json;\n  if (!t.text) continue;\n\n  const likes = t.likes || 0;\n  const retweets = t.retweets || 0;\n  const replies = t.replies || 0;\n  const quotes = t.quotes || 0;\n\n  const total = likes + (retweets * 2) + (replies * 3) + (quotes * 2);\n  const score = Math.round(total / 10) / 10;\n\n  results.push({\n    json: {\n      tweet_id: String(t.id || ''),\n      content: t.text,\n      url: t.url || '',\n      username: t.url?.split('/')[3] || 'unknown',\n      likes,\n      retweets,\n      replies,\n      engagement_score: score,\n      language: 'en',\n      scraped_at: new Date().toISOString()\n    }\n  });\n}\n\nresults.sort((a, b) => b.json.engagement_score - a.json.engagement_score);\nreturn results;"
      },
