    {
      "parameters": {
        "jsCode": "const tweets = $input.all();\nconst total = tweets.length;\n\nconst sorted = tweets.slice().sort((a, b) => {\n  const scoreB = a.json.engagement_score ? a.json.engagement_score : 0;\n  const scoreA = b.json.engagement_score ? b.json.engagement_score : 0;\n  return scoreA - scoreB;\n});\n\nconst topTweets = sorted.slice(0, 3);\n\nlet message = '🔍 Scraping concluído!\\n\\n';\nmessage += '📊 ' + total + ' tweets novos salvos\\n\\n';\nmessage += '🏆 Top 3 por engajamento:\\n\\n';\n\nfor (const t of topTweets) {\n  const parts = t.json.url ? t.json.url.split('/') : [];\n  const username = parts.length > 3 ? parts[3] : 'unknown';\n  const content = t.json.content ? t.json.content.substring(0, 80) : '';\n  const score = t.json.engagement_score ? t.json.engagement_score : 0;\n  const likes = t.json.likes ? t.json.likes : 0;\n  const retweets = t.json.retweets ? t.json.retweets : 0;\n\n  message += '👤 @' + username + '\\n';\n  message += '📝 ' + content + '...\\n';\n  message += '⭐ Score: ' + score + ' | ❤️ ' + likes + ' | 🔄 ' + retweets + '\\n\\n';\n}\n\nreturn [{ json: { message: message } }];"
      },
