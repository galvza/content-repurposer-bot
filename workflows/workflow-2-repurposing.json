      "parameters": {
        "jsCode": "// Filtra apenas posts não processados\nconst posts = $input.all();\nconst unprocessed = posts.filter(p => p.json.is_processed === false || p.json.is_processed === 'false');\n\nif (unprocessed.length === 0) {\n  return [{ json: { message: 'Nenhum post pra processar', count: 0 } }];\n}\n\nreturn unprocessed;"
