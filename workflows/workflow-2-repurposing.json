    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\nconst geminiResponse = input.geminiResponse;\n\nlet text = '';\ntry {\n  text = geminiResponse.candidates[0].content.parts[0].text;\n} catch (e) {\n  return [{ json: { error: 'Gemini não retornou texto', raw: geminiResponse } }];\n}\n\n// Limpa backticks se tiver\nlet cleanText = text.replace(/```json\\n?/g, '').replace(/```\\n?/g, '').trim();\n\n// Parseia direto — sem fazer replace nenhum\nlet parsed;\ntry {\n  parsed = JSON.parse(cleanText);\n} catch (e) {\n  return [{ json: { error: 'JSON inválido', rawText: cleanText.substring(0, 300) } }];\n}\n\nreturn [{\n  json: {\n    source_post_id: input.id || null,\n    tweet_id: input.tweet_id,\n    original_content: input.content,\n    original_url: input.url,\n    linkedin_post: parsed.linkedin_post?.text || '',\n    linkedin_hashtags: parsed.linkedin_post?.hashtags || [],\n    blog_title: parsed.blog_post?.title || '',\n    blog_meta_description: parsed.blog_post?.meta_description || '',\n    blog_content: parsed.blog_post?.content || '',\n    blog_keywords: parsed.blog_post?.keywords || [],\n    image_prompt: parsed.image_prompt || ''\n  }\n}];"
      },
